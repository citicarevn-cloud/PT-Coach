{
  "name": "personal-fitness-coach",
  "version": "0.1.0",
  "private": true,
  "description": "Personalized fitness and nutrition coach",
  "scripts": {
    "dev": "next dev",
    "build": "next build --webpack",
    "start": "next start",
    "dev:api": "tsx watch src/server.ts",
    "build:api": "tsc -p tsconfig.api.json",
    "start:api": "node dist-api/server.js",
    "test": "vitest run",
    "db:generate": "prisma generate",
    "db:migrate": "prisma migrate dev",
    "db:seed": "node --import tsx prisma/seed.ts",
    "db:studio": "prisma studio"
  },
  "dependencies": {
    "@ducanh2912/next-pwa": "10.2.9",
    "@prisma/client": "^6.8.2",
    "@tailwindcss/postcss": "^4.3.1",
    "cors": "^2.8.5",
    "express": "^5.1.0",
    "helmet": "^8.1.0",
    "lucide-react": "^1.21.0",
    "next": "^16.2.9",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "tailwindcss": "^4.3.1",
    "zod": "^3.25.28"
  },
  "devDependencies": {
    "@types/cors": "^2.8.18",
    "@types/express": "^5.0.2",
    "@types/node": "^22.15.21",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "prisma": "^6.8.2",
    "tsx": "^4.19.4",
    "typescript": "^5.8.3",
    "vitest": "^3.1.4"
  },
  "overrides": {
    "serialize-javascript": "7.0.5"
  },
  "engines": {
    "node": ">=20.9.0"
  }
